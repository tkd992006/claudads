DATABASE_URL=postgresql://postgres:postgres@localhost:5433/claude_ad

# NextAuth
NEXTAUTH_SECRET=replace-me-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth
# https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ads
# Optional custom public domain. If empty, server returns presigned GET URLs.
R2_PUBLIC_BASE=

# Comma-separated GitHub logins promoted to ADMIN on first login
ADMIN_GITHUB_LOGINS=tkd992006

# Desktop -> Web base URL (for the Electron app to call)
PUBLIC_API_BASE=http://localhost:3000
